{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "type", "version"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "version": {
      "type": "number"
    },
    "meta": {
      "type": "object"
    },
    "defaults": {
      "type": "object"
    },
    "formatting": {
      "type": "object",
      "properties": {
        "phone": {
          "type": "object",
          "properties": {
            "countryCode": {
              "type": "string"
            },
            "formatStyle": {
              "type": "string",
              "enum": ["national", "international"]
            },
            "validationPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "validationExamples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "validationMessage": {
              "type": "string"
            },
            "validationMessageKey": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "url": {
          "type": "object",
          "properties": {
            "validationPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "validationExamples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "validationMessage": {
              "type": "string"
            },
            "validationMessageKey": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "highlighting": {
      "type": "object"
    },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "severity"],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          }
        }
      }
    },
    "categoryStandards": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "geometry": {
            "type": "object",
            "properties": {
              "required": {
                "type": "string",
                "enum": ["point", "polygon"]
              },
              "recommended": {
                "type": "string",
                "enum": ["point", "polygon"]
              },
              "allowed": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["point", "polygon"]
                }
              }
            }
          },
          "lockLevel": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "cityInVenueName": {
            "type": "boolean"
          },
          "phone": {
            "type": "string",
            "enum": ["required", "recommended", "discouraged", "forbidden"]
          },
          "url": {
            "type": "string",
            "enum": ["required", "recommended", "discouraged", "forbidden"]
          },
          "openingHours": {
            "type": "string",
            "enum": ["required", "recommended", "discouraged", "forbidden"]
          },
          "navigationPoints": {
            "type": "string",
            "enum": ["required", "recommended", "discouraged", "forbidden"]
          },
          "externalProviderIds": {
            "type": "string",
            "enum": ["required", "recommended", "discouraged", "forbidden"]
          },
          "services": {
            "type": "object",
            "properties": {
              "required": {
                "type": "array",
                "items": { "type": "string" }
              },
              "recommended": {
                "type": "array",
                "items": { "type": "string" }
              },
              "discouraged": {
                "type": "array",
                "items": { "type": "string" }
              },
              "forbidden": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "street": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "houseNumber": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              }
            }
          },
          "editorNotes": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
