{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "type", "version", "items"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "chain-dataset"
    },
    "version": {
      "type": "number"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "canonicalName", "match", "policy"],
        "properties": {
          "id": {
            "type": "string"
          },
          "canonicalName": {
            "type": "string"
          },
          "match": {
            "type": "object",
            "properties": {
              "aliases": {
                "type": "array",
                "items": { "type": "string" }
              },
              "regex": {
                "type": "array",
                "items": { "type": "string" }
              },
              "categoryAnyOf": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "policy": {
            "type": "object",
            "properties": {
              "geometry": {
                "type": "object",
                "properties": {
                  "required": {
                    "type": "string",
                    "enum": ["point", "polygon"]
                  },
                  "recommended": {
                    "type": "string",
                    "enum": ["point", "polygon"]
                  },
                  "allowed": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["point", "polygon"]
                    }
                  }
                }
              },
              "lockLevel": {
                "type": "integer",
                "minimum": 1,
                "maximum": 6
              },
              "cityInVenueName": {
                "type": "boolean"
              },
              "services": {
                "type": "object",
                "properties": {
                  "required": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "recommended": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "discouraged": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "forbidden": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "phone": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "url": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "openingHours": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "externalProviderIds": {
                "type": "string",
                "enum": ["required", "recommended", "discouraged", "forbidden"]
              },
              "address": {
                "type": "object",
                "properties": {
                  "city": {
                    "type": "string",
                    "enum": ["required", "recommended", "discouraged", "forbidden"]
                  },
                  "street": {
                    "type": "string",
                    "enum": ["required", "recommended", "discouraged", "forbidden"]
                  },
                  "houseNumber": {
                    "type": "string",
                    "enum": ["required", "recommended", "discouraged", "forbidden"]
                  }
                }
              }
            }
          },
          "editorNotes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
