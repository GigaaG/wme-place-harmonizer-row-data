{
  "id": "nl",
  "type": "country-config",
  "version": 1,
  "extends": "global",
  "meta": {
    "name": "Netherlands",
    "description": "Country-specific rules for the Netherlands"
  },
  "scope": {
    "country": "nl"
  },
  "defaults": {
    "locale": "nl"
  },
  "formatting": {
    "phone": {
      "countryCode": "+31",
      "formatStyle": "national"
    }
  },
  "rules": {
    "phoneValidation": {
      "enabled": true,
      "severity": "warning"
    },
    "categoryValidation": {
      "enabled": true,
      "severity": "error"
    }
  },
  "categoryStandards": {

    "CAR_WASH": {
      "geometry": { "recommended": "point", "allowed": ["point","polygon"] },
      "lockLevel": 2,
      "requirePhone": false,
      "requireUrl": false,
      "requireOpeningHours": true,
      "requireExternalProvider": true,
      "address": {
        "city": "required",
        "street": "required",
        "houseNumber": "required"
      }
    },

    "CHARGING_STATION": {
      "geometry": { "recommended": "point", "allowed": ["point","polygon"] },
      "lockLevel": 3,
      "requirePhone": false,
      "requireUrl": false,
      "requireOpeningHours": false,
      "requireExternalProvider": false,
      "services": {
        "recommended": ["EV_CHARGING"]
      }
    },

    "GAS_STATION": {
      "geometry": { "recommended": "point", "allowed": ["point","polygon"] },
      "lockLevel": 3,
      "requirePhone": true,
