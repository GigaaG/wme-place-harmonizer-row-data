          "point",
          "polygon"
        ]
      },
      "lockLevel": 2,
      "address": {
        "city": "required",
        "street": "required",
        "houseNumber": "required"
      },
      "openingHours": "required",
      "externalProviderIds": "required"
    },
    "CHARGING_STATION": {
