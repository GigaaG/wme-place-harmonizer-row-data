{
  "id": "global",
  "type": "global-config",
  "version": 1,
  "meta": {
    "name": "Global Default Configuration",
    "description": "Base defaults for WME Place Harmonizer ROW Edition"
  },
  "defaults": {
    "locale": "en",
    "countryResolution": {
      "preferPlaceCountry": true,
      "fallbackToMapContext": true,
      "allowManualFallback": true
    },
    "matching": {
      "caseInsensitive": true,
      "normalizeWhitespace": true,
      "stripCommonPunctuation": true
    },
    "ui": {
      "showDebugTab": false,
      "defaultChannel": "stable"
    }
  },
  "highlighting": {
    "statuses": {
      "ok": "green",
      "warning": "orange",
      "error": "red",
      "whitelisted": "blue",
      "unknown": "gray"
    }
  },
  "rules": {
    "nameNormalization": {
      "enabled": true,
      "severity": "warning"
    },
    "aliasNormalization": {
      "enabled": true,
      "severity": "warning"
    },
    "brandHarmonization": {
      "enabled": true,
      "severity": "warning"
    },
    "phoneValidation": {
      "enabled": true,
      "severity": "warning"
    },
    "urlValidation": {
      "enabled": true,
      "severity": "warning"
    },
    "categoryValidation": {
      "enabled": true,
      "severity": "error"
    },
    "lockLevelRecommendation": {
      "enabled": true,
      "severity": "info"
    },
    "residentialCleanup": {
      "enabled": true,
      "severity": "warning"
    }
  },
  "mergeStrategies": {
    "chains.items": {
      "mode": "keyedMerge",
      "key": "id"
    },
    "exceptions.items": {
      "mode": "keyedMerge",
      "key": "id"
    },
    "matching.synonyms": {
      "mode": "appendUnique"
    }
  }
},
